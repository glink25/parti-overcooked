{
  "partiVersion": "0.1.0",
  "protocolVersion": 1,
  "id": "overcooked-party",
  "name": "新手上厨",
  "version": "2.0.0",
  "packageMode": "blob",
  "description": "Low-poly 3D 合作厨房派对：2-4 人挑战三局派对或怒气无尽模式，18 道菜谱、6 张地图。",
  "cover": "cover-newbie-chefs.jpg",
  "tags": [
    "co-op",
    "3d"
  ],
  "author": {
    "name": "glink25"
  },
  "entry": {
    "ui": "index.html",
    "worker": "room.worker.js"
  },
  "room": {
    "minPlayers": 2,
    "maxPlayers": 4,
    "allowSpectators": false
  },
  "sync": {
    "mode": "snapshot"
  },
  "permissions": {
    "network": false,
    "storage": "session",
    "camera": false,
    "microphone": false,
    "clipboard": false,
    "sensors": []
  },
  "actions": {
    "selectMode": {
      "payload": "{ mode: 'party' | 'endless' }"
    },
    "start": {},
    "rematch": {},
    "toLobby": {},
    "move": {
      "payload": "{ dx: number, dz: number }"
    },
    "work": {
      "payload": "{ on: boolean }"
    },
    "interact": {}
  }
}
